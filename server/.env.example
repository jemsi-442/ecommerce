NODE_ENV=development
PORT=5001
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
DATABASE_URL=mariadb://root:your_mysql_password@127.0.0.1:3306/ecommerce
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_SYNC=false
DB_SYNC_ALTER=false
CLOUDINARY_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
APP_NAME=Ecommerce
MAIL_FROM=Ecommerce <no-reply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,https://rihancollection.vercel.app
ADMIN_EMAIL=admin@ramla.com
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_NAME=Ramla Admin
AUTO_BOOTSTRAP_ADMIN=true
RIDER_EMAIL=rider@ramla.com
RIDER_PASSWORD=replace_with_rider_password
RIDER_NAME=Ramla Rider
RIDER_PHONE=0712345678
TEST_CUSTOMER_EMAIL=customer@ramla.com
TEST_CUSTOMER_PASSWORD=replace_with_test_customer_password
TEST_CUSTOMER_NAME=Test Customer
SNIPPE_API_KEY=replace_with_snippe_api_key
SNIPPE_BASE_URL=https://api.snippe.sh
SNIPPE_WEBHOOK_SECRET=replace_with_snippe_webhook_secret
SNIPPE_WEBHOOK_URL=https://your-public-domain.example/api/payments/snippe/webhook
NOTIFICATION_INSTANCE_ID=replace_with_unique_instance_name
NOTIFICATION_RELAY_INTERVAL_MS=2000
NOTIFICATION_EVENT_CLEANUP_INTERVAL_MS=600000
NOTIFICATION_EVENT_RETENTION_HOURS=24
